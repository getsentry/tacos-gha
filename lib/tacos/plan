#!/bin/bash
set -euo pipefail
# read as: cp stdout tmp && cp stderr stdout
# stdout is reserved for tf plan results
exec 3>&1 1>&2

# note: for terragrunt, tfplan must be absolute
TACOS_TFPLAN="${TACOS_TFPLAN:-$PWD/tfplan}"
TACOS_LOCK="${TACOS_LOCK:-false}"
if [ "${TERRAGRUNT_VERSION}" = "0.54.15" ]; then
    run_all=("run-all")
else
    run_all=("run" "--all")
fi

if "$TACOS_LOCK"; then
  ( set -ex
    env GETSENTRY_SAC_VERB=state-admin sudo-gcp tf-lock-acquire
  )
fi

quietly sudo-gcp terragrunt "${run_all[@]}" init

if "$TACOS_LOCK"; then
  quietly sudo-gcp terragrunt "${run_all[@]}" refresh
fi

set -x
sudo-gcp terragrunt "${run_all[@]}" plan -out "$TACOS_TFPLAN" >&3
